import random
tentativas = 10

print("----------------------------")

tema = ["programação", "jogos", "marcas"]
tema = random.choice(tema)

print(f"Tema escolhido: {tema}")

jogos = [
    "minecraft", "roblox", "fortnite", "valorant", "csgo",
    "gta", "gta 5", "league of legends", "dota", "overwatch",
    "apex", "pubg", "free fire", "call of duty", "warzone",
    "fifa", "efootball", "pes", "rocket league", "terraria",
    "stardew valley", "hollow knight", "undertale", "cuphead", "among us",
    "brawl stars", "clash royale", "clash of clans", "mobile legends", "genshin impact",
    "elden ring", "dark souls", "sekiro", "bloodborne", "skyrim",
    "cyberpunk", "hades", "dead cells", "minecraft dungeons", "the witcher 3",
    "assassins creed", "red dead redemption", "far cry", "resident evil", "silent hill",
    "batman arkham", "spider man", "god of war", "halo infinite", "halo"
]

jogo = random.choice(jogos)

mascarada = "*" * len(jogo)

print(mascarada)

while tentativas > 0:
    digitar = input("Digite a palavra: ")

    if digitar == jogo:
        print("Parabéns Você ganhou! 🎉")
        break
    else:
        tentativas -= 1
        print(f"Errado Restam {tentativas} chances!")

if tentativas == 0:
    print(f"Você perdeu A palavra era: {jogo}")

